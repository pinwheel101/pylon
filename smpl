-- [Q5] 
SELECT
    fab,
    stat_col,
    COUNT(*)                                                    AS total_numeric,
    COUNT_IF(
        original_str != CAST(TRY_CAST(original_str AS DOUBLE) AS VARCHAR)
    )                                                           AS roundtrip_mismatch,
    ROUND(
        COUNT_IF(
            original_str != CAST(TRY_CAST(original_str AS DOUBLE) AS VARCHAR)
        ) * 100.0 / COUNT(*), 6
    )                                                           AS mismatch_pct,
    -- 불일치 중 실제 오차 크기
    MAX(ABS(
        TRY_CAST(original_str AS DOUBLE)
        - TRY_CAST(CAST(TRY_CAST(original_str AS DOUBLE) AS VARCHAR) AS DOUBLE)
    ))                                                          AS max_abs_error
FROM (
    SELECT fab, 'mean_val' AS stat_col, t.val AS original_str
    FROM hive.fdc.fdc_summary_lot_iceberg
    CROSS JOIN UNNEST(mean_val) AS t(val)
    WHERE dt >= '2026-01-20' AND dt <= '2026-01-22'
      AND fab IN ('M16', 'M10', 'ICPNT')
      AND TRY_CAST(t.val AS DOUBLE) IS NOT NULL

    UNION ALL

    SELECT fab, 'stddev_val' AS stat_col, t.val AS original_str
    FROM 
    CROSS JOIN UNNEST(stddev_val) AS t(val)
    WHERE 
      AND TRY_CAST(t.val AS DOUBLE) IS NOT NULL

    UNION ALL

    SELECT fab, 'max_val' AS stat_col, t.val AS original_str
    FROM hive.fdc.fdc_summary_lot_iceberg
    CROSS JOIN UNNEST(max_val) AS t(val)
    WHERE TRY_CAST(t.val AS DOUBLE) IS NOT NULL
) sub
GROUP BY fab, stat_col
ORDER BY stat_col, fab;


-- [Q6] 
SELECT
    fab,
    COUNT(*)                                                    AS mismatch_count,
    -- 상대 오차 (relative error) 분포
    APPROX_PERCENTILE(
        ABS(TRY_CAST(param_value AS DOUBLE) - TRY_CAST(CAST(TRY_CAST(param_value AS DOUBLE) AS VARCHAR) AS DOUBLE))
        / NULLIF(ABS(TRY_CAST(param_value AS DOUBLE)), 0),
        ARRAY[0.5, 0.9, 0.99, 1.0]
    )                                                           AS relative_error_percentiles
FROM hive.fdc.fdc_trace_flat
WHERE dt >= '2026-01-20' AND dt <= '2026-01-22'
  AND fab IN ('M16', 'M10', 'ICPNT')
  AND TRY_CAST(param_value AS DOUBLE) IS NOT NULL
  AND CAST(param_value AS VARCHAR) != CAST(TRY_CAST(param_value AS DOUBLE) AS VARCHAR)
GROUP BY fab
ORDER BY fab;


