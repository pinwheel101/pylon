[Q2-b] 
SELECT
    fab,
    COUNT(*)                                                    AS total_mismatch,

    -- Case 1: DOUBLE 변환 후 값이 수치적으로 동일 (표현 차이만)
    -- TRY_CAST 두 번 해서 DOUBLE 값 자체를 비교
    COUNT_IF(
        TRY_CAST(param_value AS DOUBLE)
        = TRY_CAST(CAST(TRY_CAST(param_value AS DOUBLE) AS VARCHAR) AS DOUBLE)
    )                                                           AS representation_only,

    -- Case 2: DOUBLE 변환 후 값이 수치적으로도 다름 (실제 정밀도 손실)
    COUNT_IF(
        TRY_CAST(param_value AS DOUBLE)
        != TRY_CAST(CAST(TRY_CAST(param_value AS DOUBLE) AS VARCHAR) AS DOUBLE)
    )                                                           AS actual_value_loss,

    -- 불일치 원인 세분화
    -- trailing zero: 원본에 trailing zero가 있는 경우
    COUNT_IF(
        REGEXP_LIKE(param_value, '\.\d*0+$')
    )                                                           AS trailing_zero_pattern,

    -- scientific notation: DOUBLE 표현이 E를 포함
    COUNT_IF(
        CAST(TRY_CAST(param_value AS DOUBLE) AS VARCHAR) LIKE '%E%'
    )                                                           AS scientific_notation_pattern,

    -- 유효숫자 15자리 초과 (실제 정밀도 한계)
    COUNT_IF(
        LENGTH(REGEXP_REPLACE(
            REGEXP_REPLACE(param_value, '[^0-9]', ''),
            '^0+', ''
        )) > 15
    )                                                           AS exceeds_15_digits,

    -- 소수점 이하 자릿수가 많은 경우 (trailing zero 제외)
    COUNT_IF(
        LENGTH(REGEXP_REPLACE(param_value, '^[^.]*\.?', '')) > 10
        AND NOT REGEXP_LIKE(param_value, '\.\d*0+$')
    )                                                           AS long_decimal_no_trailing

FROM 


